# AI API 配置（按优先级：MiniMax > DeepSeek > OpenAI）
# MiniMax API
MINIMAX_API_KEY=sk-xxx
MINIMAX_BASE_URL=https://api.minimax.io

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API
OPENAI_API_KEY=sk-xxx

# PostgreSQL（pgvector 扩展用于向量存储）
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/schedule_app

# 服务配置
HOST=0.0.0.0
PORT=8000

# 用量表是否同时保存「用户原话 + AI 全文」（默认 true，所有 user_id 含 anonymous 均生效；生产建议 false）
USAGE_LOG_INCLUDE_CONVERSATION=true

# 用量表是否保存「提供商完整响应」JSON 字符串（管理台可折叠查看；体积大时生产可 false）
USAGE_LOG_INCLUDE_LLM_RAW=true
